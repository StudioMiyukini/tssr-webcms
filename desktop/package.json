{
  "name": "tssr-local",
  "version": "1.0.0",
  "description": "TSSR — version locale hors-ligne (application de bureau)",
  "author": "Studio Miyukini",
  "license": "UNLICENSED",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "sync": "node sync.js",
    "serve": "node server.js",
    "dist": "electron-builder --win",
    "dist:portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.miyukini.tssr.local",
    "productName": "TSSR Local",
    "files": [
      "main.js",
      "server.js",
      "sync.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist/client",
        "to": "client"
      }
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "artifactName": "TSSR-Local-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "TSSR-Local-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "TSSR Local"
    },
    "directories": {
      "output": "out"
    }
  }
}
