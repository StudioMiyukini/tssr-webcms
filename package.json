{
  "name": "webcms",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "start:local": "cross-env NODE_ENV=development SERVE_STATIC=1 tsx server/index.ts",
    "build:portable": "npm run build && node scripts/build-portable.mjs",
    "export": "node scripts/export-site.mjs",
    "import": "node scripts/import-site.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test client/src/lib/page-blocks.test.ts client/src/lib/notes.test.ts server/lib/cache.test.ts server/lib/security.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx server/db/seed.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.81.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.36.4",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^18.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tanstack/router-devtools": "^1.81.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.16",
    "@types/pdfkit": "^0.13.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.28.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
