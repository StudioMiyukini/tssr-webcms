<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS comme reverse proxy devant le CMS (Node sur http://localhost:3460).
  Permet de servir le site sur le port 80 (http://localhost ou http://NOM-DU-POSTE)
  sans afficher le numéro de port.

  Prérequis IIS (à installer une seule fois) :
    1. « URL Rewrite »  : https://www.iis.net/downloads/microsoft/url-rewrite
    2. « Application Request Routing (ARR) » : https://www.iis.net/downloads/microsoft/application-request-routing
    3. Dans IIS Manager → nœud du serveur → « Application Request Routing Cache »
       → « Server Proxy Settings… » → cocher « Enable proxy ».

  Mise en place :
    - Crée un site IIS (ou utilise « Default Web Site ») pointant sur un dossier
      vide, et place CE fichier web.config dedans.
    - Le CMS Node doit tourner en parallèle (npm run start:local) sur le PORT ci-dessous.
    - Adapte le port 3460 ci-dessous si tu en utilises un autre.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="CMS-ReverseProxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3460/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
